@module "thread_test"

@use "std_thread" as thread
@use "std_libc"   as c

pub const main -> fn () int {
  // pthread_mutex_t is 40 bytes on Linux x86_64
  // allocate on heap so it has proper size
  let mutex: *int = cast<*int>(c::malloc(40));

  let r: int = thread::pthread_mutex_init(mutex, cast<*void>(0));
  if (r != 0) {
    c::puts("FAIL  mutex init");
    free(cast<*void>(mutex));
    return 1;
  }
  c::puts("PASS  mutex init");

  thread::pthread_mutex_lock(mutex);
  c::puts("PASS  mutex lock");
  thread::pthread_mutex_unlock(mutex);
  c::puts("PASS  mutex unlock");

  thread::pthread_mutex_destroy(mutex);
  c::puts("PASS  mutex destroy");

  free(cast<*void>(mutex));
  c::puts("PASS  cleanup");

  return 0;
}

